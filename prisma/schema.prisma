generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OrgUnit {
  id          String     @id @default(uuid())
  name        String     @unique
  code        String     @unique
  description String?
  level       Int        @default(0)
  path        String?
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  type        String     @default("functional")
  employees   Employee[]
  parent      OrgUnit?   @relation("OrgHierarchy", fields: [parentId], references: [id])
  children    OrgUnit[]  @relation("OrgHierarchy")
  users       User[]
}

model User {
  id                            String                      @id @default(uuid())
  name                          String
  email                         String                      @unique
  phone                         String?
  passwordHash                  String?                     // nullable for Google OAuth–only users
  status                        String                      @default("active")
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt
  orgUnitId                     String?
  employeeId                    String?                     @unique
  policyVersion                 Int                         @default(1)
  announcements                 Announcement[]
  auditLogs                     AuditLog[]
  helpTicketsResolved           HelpTicket[]
  sessions                      Session[]
  tasksCreated                  Task[]
  attendanceVerificationBatches AttendanceVerificationBatch[]
  employee                      Employee?                   @relation(fields: [employeeId], references: [id])
  orgUnit                       OrgUnit?                    @relation(fields: [orgUnitId], references: [id])
  roles                         UserRole[]
  settings                      UserSettings?
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  policies    RolePolicy[]
  users       UserRole[]
}

model Policy {
  id          String       @id @default(uuid())
  key         String       @unique
  description String?
  category    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  isActive    Boolean      @default(true)
  pageId      String?
  page        UiPage?      @relation(fields: [pageId], references: [id])
  roles       RolePolicy[]

  @@index([pageId])
}

model UiPage {
  id           String   @id @default(uuid())
  pageKey      String   @unique
  pageName     String
  path         String   @unique
  policyPrefix String
  autoGenerate Boolean  @default(true)
  icon         String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  policies     Policy[]

  @@index([isActive])
  @@index([order])
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@unique([userId])
  @@index([userId])
  @@index([roleId])
}

model RolePolicy {
  roleId    String
  policyId  String
  createdAt DateTime @default(now())
  policy    Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, policyId])
  @@index([roleId])
  @@index([policyId])
}

model Employee {
  id                   String           @id @default(uuid())
  firstName            String
  lastName             String?
  employeeCode         String?          @unique
  phone                String?
  joiningDate          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  orgUnitId            String?
  aadhaar              String?
  autoNumber           String?
  cardNumber           String?          @unique
  companyEmail         String?
  departmentId         String?
  designationId        String?
  externalId           String?          @unique
  gender               String?
  interviewDate        DateTime?
  metadata             Json?
  personalEmail        String?
  profileImageUrl      String?
  secondaryPhone       String?
  shiftEnd             String?
  shiftStart           String?
  status               String           @default("ACTIVE")
  timePolicyId         String?
  weeklyOff            String?
  zohoId               String?
  weeklyOffCalculation String?
  mobileOtp            String?
  lastInterviewDate    DateTime?
  personelImage        String?
  attendance           Attendance[]
  claims               Claim[]
  department           Department?      @relation(fields: [departmentId], references: [id])
  designation          Designation?     @relation(fields: [designationId], references: [id])
  orgUnit              OrgUnit?         @relation(fields: [orgUnitId], references: [id])
  timePolicy           TimePolicy?      @relation(fields: [timePolicyId], references: [id])
  targets              EmployeeTarget[]
  helpTickets          HelpTicket[]
  tasks                Task[]
  user                 User?
  announcements        Announcement[]   @relation("AnnouncementRecipients")

  @@index([orgUnitId])
  @@index([departmentId])
  @@index([designationId])
  @@index([status])
  @@index([firstName])
}

model Department {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Designation {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model TimePolicy {
  id            String     @id @default(uuid())
  code          String     @unique
  name          String
  isSinglePunch Boolean    @default(false)
  scheduleJson  Json?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employees     Employee[]
}

model DataImportLog {
  id              String    @id @default(uuid())
  sourceName      String
  sourceUrl       String?
  status          String    @default("pending")
  recordsTotal    Int       @default(0)
  recordsImported Int       @default(0)
  recordsFailed   Int       @default(0)
  errorMessage    String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  metadata        Json?
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  date        DateTime
  checkInAt   DateTime?
  checkOutAt  DateTime?
  status      String
  lat         Float?
  lng         Float?
  geoAccuracy Int?
  meta        Json?
  createdAt   DateTime  @default(now())
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmployeeTarget {
  id          String   @id @default(uuid())
  employeeId  String
  periodStart DateTime
  periodEnd   DateTime
  metric      String
  value       Float
  achieved    Float    @default(0)
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  assigneeId  String?
  creatorId   String?
  status      String    @default("open")
  priority    String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  assignee    Employee? @relation(fields: [assigneeId], references: [id])
  creator     User?     @relation(fields: [creatorId], references: [id])
}

model Announcement {
  id          String     @id @default(uuid())
  title       String
  body        String
  createdById String?
  scope       String
  createdAt   DateTime   @default(now())
  createdBy   User?      @relation(fields: [createdById], references: [id])
  recipients  Employee[] @relation("AnnouncementRecipients")
}

model Claim {
  id          String            @id @default(uuid())
  employeeId  String
  amount      Float
  currency    String            @default("INR")
  category    String
  status      String            @default("pending")
  submittedAt DateTime          @default(now())
  employee    Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attachments ClaimAttachment[]
}

model ClaimAttachment {
  id      String  @id @default(uuid())
  claimId String
  url     String
  name    String?
  claim   Claim   @relation(fields: [claimId], references: [id], onDelete: Cascade)
}

model HelpTicket {
  id             String    @id @default(uuid())
  employeeId     String
  subject        String
  description    String
  category       String    @default("attendance")
  status         String    @default("open")
  priority       String    @default("medium")
  relatedData    Json?
  response       String?
  resolvedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  raisedByRole   String    @default("EMPLOYEE")
  managerId      String?
  assignedToRole String    @default("MDO")
  assignedToId   String?
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  resolvedBy     User?     @relation(fields: [resolvedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedToRole])
  @@index([assignedToId])
  @@index([managerId])
}

model Session {
  id             String   @id @default(uuid())
  userId         String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  employeeCardNo String?
  loginType      String   @default("mdo")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String?
  email     String?
  code      String
  type      String   @default("login")
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([email, code])
}

model UserSettings {
  id                 String   @id @default(uuid())
  userId             String   @unique
  theme              String   @default("light")
  emailNotifications Boolean  @default(true)
  smsNotifications   Boolean  @default(false)
  loginMethod        String   @default("password")
  timezone           String   @default("Asia/Kolkata")
  language           String   @default("en")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiRouting {
  id                  String    @id @default(uuid())
  name                String    @unique
  description         String?
  endpoint            String?
  method              String    @default("GET")
  sourceType          String    @default("api")
  csvFilePath         String?
  csvUrl              String?
  headers             Json?
  isActive            Boolean   @default(true)
  status              String    @default("draft")
  syncEnabled         Boolean   @default(false)
  syncIntervalHours   Int       @default(0)
  syncIntervalMinutes Int       @default(10)
  syncSchedule        String?
  lastSyncAt          DateTime?
  lastSyncStatus      String?
  lastTestAt          DateTime?
  lastTestStatus      String?
  syncProgressCurrent Int       @default(0)
  syncProgressTotal   Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  category    String   @default("general")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SmsLog {
  id             String    @id @default(uuid())
  recipientPhone String
  messageType    String    @default("OTP")
  messageText    String?
  status         String    @default("pending")
  apiResponse    Json?
  apiMessageId   String?
  customerRef    String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([recipientPhone])
  @@index([status])
  @@index([apiMessageId])
}

model SalesStaffSummary {
  id        String    @id @default(uuid())
  dat       String
  unit      String?
  smno      String
  sm        String?
  divi      String?
  btype     String?
  qty       Int       @default(0)
  netSale   Float     @default(0)
  updon     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([smno])
  @@index([dat])
  @@index([unit])
  @@index([updatedAt])
}

model SalesData {
  id         String    @id @default(uuid())
  smno       String?
  sm         String?
  shrtname   String?
  dept       String?
  brand      String?
  email      String?
  totalSale  Float     @default(0)
  inhouseSal Float     @default(0)
  prDays     Int       @default(0)
  billMonth  DateTime?
  updOn      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([smno])
  @@index([shrtname])
  @@index([dept])
  @@index([brand])
  @@index([billMonth])
  @@index([updatedAt])
}

model EmpManager {
  mid             String   @id(map: "emp_manager_new_pkey")
  mcardno         String   @unique
  mdepartmentIds  String[] @default([])
  mdesignationIds String[] @default([])
  morgUnitIds     String[] @default([])
  mis_extinct     Boolean  @default(false)

  @@index([mcardno])
  @@index([mis_extinct])
  @@map("emp_manager")
}

model AttendanceVerificationBatch {
  id             String                  @id @default(cuid())
  monthStart     DateTime                @db.Date
  createdByUserId String?
  createdAt      DateTime                @default(now())
  notes          String?
  submittedAt    DateTime?
  verifications  AttendanceVerification[]
  createdBy      User?                   @relation(fields: [createdByUserId], references: [id])

  @@index([monthStart])
  @@index([createdByUserId])
}

model AttendanceVerification {
  id                    String                     @id @default(cuid())
  batchId               String
  employeeId            String
  date                  DateTime                   @db.Date
  status                String                     // CORRECT | NOT_CORRECT
  query                 String?                    // Reason when NOT_CORRECT (manager)
  hrStatus              String?                    // IN_PROGRESS | NEED_INFO | RESOLVED | REJECTED
  hrRemark              String?                    // HR response
  reraiseRemark         String?                    // Manager re-raise remark
  dismissedByManagerAt  DateTime?                  // Manager removed from list (soft-hide, audit kept)
  updatedByUserId       String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  batch                 AttendanceVerificationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([batchId])
  @@index([batchId, status])
}
